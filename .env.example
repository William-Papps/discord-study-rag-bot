# Discord
DISCORD_BOT_TOKEN=
DISCORD_ENABLE_MESSAGE_CONTENT_INTENT=true
DISCORD_ENABLE_PREFIX_COMMANDS=false
DISCORD_COMMAND_PREFIX=!
DISCORD_SYNC_ALL_VISIBLE_CHANNELS=true
DISCORD_GUILD_IDS=
DISCORD_IGNORED_CHANNEL_IDS=
DISCORD_ALLOWED_USER_IDS=

# Local persistence
DATABASE_PATH=data/messages.db
CHROMA_PATH=data/chroma
CHROMA_COLLECTION=discord_notes

# Retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.2
RETRIEVAL_MIN_RESULTS=1

# Chunking
CHUNK_TARGET_TOKENS=500
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_MESSAGES=1
CHUNK_MAX_TIME_GAP_MINUTES=120

# Sync
DISCORD_HISTORY_LIMIT=0

# AI providers
EMBEDDING_PROVIDER=openai
ANSWER_PROVIDER=openai
IMAGE_TEXT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
MAX_ATTACHMENT_BYTES=5000000

# Logging
LOG_LEVEL=INFO
